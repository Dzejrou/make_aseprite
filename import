#!/bin/sh

set -eu

usage() {
  cat <<'EOF'
Usage: ./import [--in DIRECTORY] [--out FILE]

Options:
  --in DIRECTORY   Input character directory. Defaults to the current directory.
  --out FILE       Output .aseprite file. Defaults to out.aseprite.
  --help           Show this help message.

Environment:
  ASEPRITE_BIN     Optional explicit path to the Aseprite executable.
EOF
}

find_aseprite() {
  if [ "${ASEPRITE_BIN:-}" ]; then
    printf '%s\n' "$ASEPRITE_BIN"
    return 0
  fi

  if command -v aseprite >/dev/null 2>&1; then
    command -v aseprite
    return 0
  fi

  for candidate in \
    "$HOME/Applications/Aseprite.app/Contents/MacOS/aseprite" \
    /Applications/Aseprite.app/Contents/MacOS/aseprite \
    /Applications/Aseprite.app/Contents/MacOS/Aseprite
  do
    if [ -x "$candidate" ]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done

  return 1
}

absolute_dir_path() {
  case "$1" in
    /*)
      CDPATH= cd -- "$1" && pwd -P
      ;;
    *)
      CDPATH= cd -- "$1" && pwd -P
      ;;
  esac
}

absolute_file_path() {
  file_path="$1"
  file_dir=$(dirname -- "$file_path")
  file_name=$(basename -- "$file_path")

  case "$file_dir" in
    /*)
      printf '%s/%s\n' "$file_dir" "$file_name"
      ;;
    *)
      printf '%s/%s/%s\n' "$(pwd -P)" "$file_dir" "$file_name"
      ;;
  esac
}

find_lua_script() {
  script_name="$1"

  if [ -f "$script_dir/$script_name" ]; then
    printf '%s\n' "$script_dir/$script_name"
    return 0
  fi

  if [ -f "$script_dir/scripts/$script_name" ]; then
    printf '%s\n' "$script_dir/scripts/$script_name"
    return 0
  fi

  return 1
}

run_aseprite_filtered() {
  stdout_file=$(mktemp "${TMPDIR:-/tmp}/import.stdout.XXXXXX")
  stderr_file=$(mktemp "${TMPDIR:-/tmp}/import.stderr.XXXXXX")

  cleanup() {
    rm -f "$stdout_file" "$stderr_file"
  }

  trap cleanup EXIT HUP INT TERM

  if "$@" >"$stdout_file" 2>"$stderr_file"; then
    status=0
  else
    status=$?
  fi

  grep -F -v "handle-pose.lua:58: attempt to index a nil value (local 'dlg')" "$stdout_file" || true
  grep -F -v "handle-pose.lua:58: attempt to index a nil value (local 'dlg')" "$stderr_file" >&2 || true

  cleanup
  trap - EXIT HUP INT TERM
  return "$status"
}

input_dir="."
output_path="out.aseprite"

while [ "$#" -gt 0 ]; do
  case "$1" in
    --in)
      [ "$#" -ge 2 ] || {
        echo "import: missing value for --in" >&2
        exit 1
      }
      input_dir="$2"
      shift 2
      ;;
    --out)
      [ "$#" -ge 2 ] || {
        echo "import: missing value for --out" >&2
        exit 1
      }
      output_path="$2"
      shift 2
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    *)
      echo "import: unknown argument: $1" >&2
      usage >&2
      exit 1
      ;;
  esac
done

aseprite_bin="$(find_aseprite)" || {
  echo "import: could not find Aseprite. Set ASEPRITE_BIN or add 'aseprite' to PATH." >&2
  exit 1
}

script_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
lua_script="$(find_lua_script import.lua)" || {
  echo "import: could not locate import.lua relative to $script_dir" >&2
  exit 1
}
input_dir_abs="$(absolute_dir_path "$input_dir")"
output_path_abs="$(absolute_file_path "$output_path")"

run_aseprite_filtered "$aseprite_bin" --batch \
  --script-param "in=$input_dir_abs" \
  --script-param "out=$output_path_abs" \
  --script "$lua_script"
